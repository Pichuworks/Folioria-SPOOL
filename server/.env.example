# S.P.O.O.L. server environment variables
# Copy to .env and fill in values

# SQLite database path (default: folioria.db)
SPOOL_DB=folioria.db

# Server port (default: 3000)
PORT=3000

# Session cookie Secure flag (default: true; set to 0 for plain HTTP dev only)
# SPOOL_COOKIE_SECURE=0

# Log level: silent | fatal | error | warn | info | debug | trace (default: info)
# SPOOL_LOG_LEVEL=info

# Upload directory (default: ~/.local/share/spool/uploads)
# SPOOL_UPLOAD_DIR=

# Email (Resend) — omit to disable email sending
# SPOOL_RESEND_API_KEY=re_xxxxxxxxxxxx
# SPOOL_MAIL_FROM=noreply@example.com
# SPOOL_PUBLIC_ORIGIN=https://spool.example.com
